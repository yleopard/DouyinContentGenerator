{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=douyin_content;Username=postgres;Password=douyin2026;SSL Mode=Disable;Include Error Detail=true;Pooling=false",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-jwt-key-at-least-32-characters-long"
  },
  "AIProviders": {
    "ImageGeneration": {
      "ActiveProvider": "tongyi_wanxiang",
      "TongyiWanxiang": {
        "ApiKey": "${TONGYI_API_KEY}",
        "Model": "wan2.1-t2i-turbo"
      },
      "GlmCogView": {
        "ApiKey": "${GLM_API_KEY}",
        "Model": "cogview-3-flash"
      },
      "XiaomiMiMo": {
        "ApiKey": "${XIAOMI_API_KEY}",
        "Model": "MiMo-V2-Flash"
      },
      "WenxinYige": {
        "ApiKey": "${WENXIN_API_KEY}",
        "SecretKey": "${WENXIN_SECRET_KEY}",
        "Model": "ernie-vilg-v2"
      }
    },
    "TextGeneration": {
      "ActiveProvider": "tongyi_qianwen",
      "TongyiQianwen": {
        "ApiKey": "${TONGYI_API_KEY}",
        "Model": "qwen-turbo"
      },
      "Glm": {
        "ApiKey": "${GLM_API_KEY}",
        "Model": "glm-4-flash"
      },
      "XiaomiMiMo": {
        "ApiKey": "${XIAOMI_API_KEY}",
        "Model": "MiMo-V2-Flash"
      },
      "WenxinYiyan": {
        "ApiKey": "${WENXIN_API_KEY}",
        "SecretKey": "${WENXIN_SECRET_KEY}",
        "Model": "ernie-bot-4"
      }
    }
  },
  "CostControl": {
    "DailyBudget": 200.0,
    "AlertThreshold": 0.8,
    "AutoPause": true
  },
  "GenerationStrategy": {
    "Image": {
      "RetryTimes": 3,
      "TimeoutSeconds": 120,
      "MaxConcurrency": 3
    },
    "Text": {
      "RetryTimes": 2,
      "VariantsCount": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
